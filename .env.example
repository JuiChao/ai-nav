# Google AdSense 环境变量配置模板
# 复制此文件为 .env.local 并填入您自己的配置

# Google AdSense 发布商 ID (格式: ca-pub-XXXXXXXXXXXXXXXX)
# 如果配置了此项，网站将自动引入 AdSense 基础脚本并开启自动广告（如果 AdSense 账号内启用了 Auto Ads）
NEXT_PUBLIC_GOOGLE_ADSENSE_PID=ca-pub-8921283801578142

# 各广告位的 Slot ID (数字格式)
# 填入以下各项后，对应的广告位将会展示 Google Ad 单元，否则自动回退为网站原有的自定义赞助商广告

# 顶部横幅广告位 ID
NEXT_PUBLIC_ADSENSE_BANNER_SLOT=

# 页面内容中内联广告位 ID
NEXT_PUBLIC_ADSENSE_INLINE_SLOT=

# 右侧边栏广告位 ID
NEXT_PUBLIC_ADSENSE_SIDEBAR_SLOT=
